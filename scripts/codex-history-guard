#!/usr/bin/env python3
"""
Codex History Guard.

Archive, index, search, and restore Codex Desktop chat history across model,
provider, CC Switch, or API-key/OAuth login changes.

The tool reads local Codex history files only. It does not call model APIs, does
not use tokens, and intentionally does not copy auth.json.
"""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import shutil
import sqlite3
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Iterable


DEFAULT_VAULT = Path(os.environ.get("CODEX_HISTORY_VAULT", "~/.codex-history-vault")).expanduser()
DEFAULT_CODEX_HOME = Path(os.environ.get("CODEX_HOME", "~/.codex")).expanduser()


def now_stamp() -> str:
    return datetime.now().strftime("%Y%m%d-%H%M%S")


def iso_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def iso_to_epoch(value: str) -> int:
    if not value:
        return 0
    normalized = value.replace("Z", "+00:00")
    try:
        return int(datetime.fromisoformat(normalized).timestamp())
    except ValueError:
        return 0


def stable_source_id(path: Path) -> str:
    resolved = str(path.expanduser().resolve())
    digest = hashlib.sha1(resolved.encode("utf-8")).hexdigest()[:10]
    name = path.name or "codex"
    return f"{name}-{digest}"


def ensure_dir(path: Path) -> None:
    path.mkdir(parents=True, exist_ok=True)


def copy_if_changed(src: Path, dst: Path) -> bool:
    ensure_dir(dst.parent)
    if dst.exists():
        try:
            s_stat = src.stat()
            d_stat = dst.stat()
            if src.suffix == ".jsonl":
                if s_stat.st_size < d_stat.st_size:
                    return False
                if s_stat.st_size == d_stat.st_size:
                    return False
                try:
                    with src.open("rb") as src_fh, dst.open("ab") as dst_fh:
                        src_fh.seek(d_stat.st_size)
                        shutil.copyfileobj(src_fh, dst_fh)
                except OSError:
                    return False
                try:
                    os.utime(dst, (s_stat.st_atime, s_stat.st_mtime))
                except OSError:
                    pass
                return True
            if s_stat.st_size == d_stat.st_size and int(s_stat.st_mtime) <= int(d_stat.st_mtime):
                return False
        except OSError:
            pass
    shutil.copy2(src, dst)
    return True


def iter_files(root: Path) -> Iterable[Path]:
    if not root.exists():
        return
    for path in root.rglob("*"):
        if path.is_file():
            yield path


def copy_tree_incremental(src_root: Path, dst_root: Path) -> int:
    count = 0
    if not src_root.exists():
        return 0
    for src in iter_files(src_root):
        rel = src.relative_to(src_root)
        if copy_if_changed(src, dst_root / rel):
            count += 1
    return count


def backup_sqlite_file(src: Path, dst: Path) -> bool:
    ensure_dir(dst.parent)
    try:
        uri = f"file:{src}?mode=ro"
        with sqlite3.connect(uri, uri=True) as source, sqlite3.connect(dst) as target:
            source.backup(target)
        return True
    except Exception:
        try:
            shutil.copy2(src, dst)
            for suffix in ("-wal", "-shm"):
                side = Path(str(src) + suffix)
                if side.exists():
                    shutil.copy2(side, Path(str(dst) + suffix))
            return True
        except Exception:
            return False


def extract_text(content: Any) -> str:
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return ""
    parts: list[str] = []
    for item in content:
        if not isinstance(item, dict):
            continue
        typ = item.get("type")
        if typ in {"input_text", "output_text", "text"}:
            text = item.get("text")
            if isinstance(text, str):
                parts.append(text)
    return "\n".join(parts).strip()


def is_boilerplate_message(text: str) -> bool:
    stripped = text.lstrip()
    return stripped.startswith("<environment_context>") or stripped.startswith("# AGENTS.md instructions")


def compact_json(value: Any) -> str:
    if value is None:
        return ""
    if isinstance(value, str):
        return value
    return json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(",", ":"))


def session_id_from_path(path: Path) -> str:
    match = re.search(r"([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})", path.name)
    return match.group(1) if match else path.stem


@dataclass
class SessionSummary:
    session_id: str
    title: str
    first_ts: str
    last_ts: str
    cwd: str
    model_provider: str
    source_id: str
    archive_path: str
    original_relpath: str
    user_messages: int
    assistant_messages: int
    searchable_text: str


@dataclass
class StateThreadRecord:
    session_id: str
    rollout_path: str
    created_at: int
    updated_at: int
    source: str
    model_provider: str
    cwd: str
    title: str
    sandbox_policy: str
    approval_mode: str
    has_user_event: int
    cli_version: str
    first_user_message: str
    model: str
    reasoning_effort: str
    thread_source: str
    preview: str


def summarize_session(path: Path, source_id: str, archive_root: Path) -> SessionSummary | None:
    session_id = ""
    first_ts = ""
    last_ts = ""
    cwd = ""
    model_provider = ""
    title = ""
    user_messages = 0
    assistant_messages = 0
    search_parts: list[str] = []

    try:
        rel = str(path.relative_to(archive_root))
    except ValueError:
        rel = path.name

    try:
        with path.open("r", encoding="utf-8", errors="replace") as fh:
            for raw in fh:
                raw = raw.strip()
                if not raw:
                    continue
                try:
                    event = json.loads(raw)
                except json.JSONDecodeError:
                    continue
                ts = event.get("timestamp") or ""
                if ts:
                    first_ts = first_ts or ts
                    last_ts = ts

                if event.get("type") == "session_meta":
                    payload = event.get("payload") or {}
                    if isinstance(payload, dict):
                        session_id = session_id or str(payload.get("id") or payload.get("session_id") or "")
                        cwd = str(payload.get("cwd") or cwd or "")
                        model_provider = str(payload.get("model_provider") or model_provider or "")
                    continue

                if event.get("type") != "response_item":
                    continue
                payload = event.get("payload") or {}
                if not isinstance(payload, dict) or payload.get("type") != "message":
                    continue
                role = payload.get("role")
                if role not in {"user", "assistant"}:
                    continue
                text = extract_text(payload.get("content"))
                if not text:
                    continue
                if role == "user":
                    user_messages += 1
                    if not title and not is_boilerplate_message(text):
                        title = " ".join(text.split())[:120]
                elif role == "assistant":
                    assistant_messages += 1
                if not is_boilerplate_message(text):
                    search_parts.append(f"{role}: {text}")
    except OSError:
        return None

    if not session_id:
        session_id = path.stem.replace("rollout-", "")
    if not title:
        title = Path(cwd).name if cwd else path.stem

    return SessionSummary(
        session_id=session_id,
        title=title,
        first_ts=first_ts,
        last_ts=last_ts,
        cwd=cwd,
        model_provider=model_provider,
        source_id=source_id,
        archive_path=str(path),
        original_relpath=rel,
        user_messages=user_messages,
        assistant_messages=assistant_messages,
        searchable_text="\n".join(search_parts),
    )


def parse_state_thread(path: Path) -> StateThreadRecord | None:
    session_id = ""
    created_ts = ""
    updated_ts = ""
    cwd = ""
    model_provider = ""
    source = "vscode"
    thread_source = ""
    cli_version = ""
    model = ""
    reasoning_effort = ""
    sandbox_policy = ""
    approval_mode = ""
    title = ""
    first_user_message = ""
    preview = ""
    user_messages = 0

    try:
        with path.open("r", encoding="utf-8", errors="replace") as fh:
            for raw in fh:
                raw = raw.strip()
                if not raw:
                    continue
                try:
                    event = json.loads(raw)
                except json.JSONDecodeError:
                    continue

                ts = event.get("timestamp") or ""
                if ts:
                    created_ts = created_ts or ts
                    updated_ts = ts

                event_type = event.get("type")
                payload = event.get("payload") or {}
                if event_type == "session_meta" and isinstance(payload, dict):
                    session_id = session_id or str(payload.get("id") or payload.get("session_id") or "")
                    created_ts = created_ts or str(payload.get("timestamp") or "")
                    cwd = str(payload.get("cwd") or cwd or "")
                    source = str(payload.get("source") or source or "vscode")
                    thread_source = str(payload.get("thread_source") or thread_source or "")
                    model_provider = str(payload.get("model_provider") or model_provider or "")
                    cli_version = str(payload.get("cli_version") or cli_version or "")
                    continue

                if event_type == "turn_context" and isinstance(payload, dict):
                    cwd = str(payload.get("cwd") or cwd or "")
                    model = str(payload.get("model") or model or "")
                    reasoning_effort = str(payload.get("effort") or reasoning_effort or "")
                    sandbox_policy = compact_json(payload.get("file_system_sandbox_policy") or payload.get("sandbox_policy") or sandbox_policy)
                    approval_mode = compact_json(payload.get("approval_policy") or approval_mode)
                    collaboration = payload.get("collaboration_mode")
                    if isinstance(collaboration, dict):
                        settings = collaboration.get("settings")
                        if isinstance(settings, dict):
                            reasoning_effort = str(settings.get("reasoning_effort") or reasoning_effort or "")
                    continue

                if event_type != "response_item" or not isinstance(payload, dict):
                    continue
                if payload.get("type") != "message":
                    continue
                role = payload.get("role")
                if role not in {"user", "assistant"}:
                    continue
                text = extract_text(payload.get("content"))
                if not text or is_boilerplate_message(text):
                    continue
                preview = preview or text[:500]
                if role == "user":
                    user_messages += 1
                    if not first_user_message:
                        first_user_message = text[:1000]
                    if not title:
                        title = " ".join(text.split())[:120]
    except OSError:
        return None

    session_id = session_id or session_id_from_path(path)
    created_at = iso_to_epoch(created_ts) or int(path.stat().st_mtime)
    updated_at = iso_to_epoch(updated_ts) or int(path.stat().st_mtime)
    if not title:
        title = Path(cwd).name if cwd else session_id
    if not sandbox_policy:
        sandbox_policy = "{}"
    if not approval_mode:
        approval_mode = "on-request"
    return StateThreadRecord(
        session_id=session_id,
        rollout_path=str(path),
        created_at=created_at,
        updated_at=updated_at,
        source=source or "vscode",
        model_provider=model_provider or "openai",
        cwd=cwd,
        title=title,
        sandbox_policy=sandbox_policy,
        approval_mode=approval_mode,
        has_user_event=1 if user_messages else 0,
        cli_version=cli_version,
        first_user_message=first_user_message,
        model=model,
        reasoning_effort=reasoning_effort,
        thread_source=thread_source,
        preview=preview,
    )


def write_jsonl(path: Path, rows: Iterable[dict[str, Any]]) -> int:
    ensure_dir(path.parent)
    count = 0
    with path.open("w", encoding="utf-8") as fh:
        for row in rows:
            fh.write(json.dumps(row, ensure_ascii=False, sort_keys=True) + "\n")
            count += 1
    return count


def rebuild_index(vault: Path) -> int:
    rows: list[dict[str, Any]] = []
    sessions_root = vault / "sources"
    if sessions_root.exists():
        for source_dir in sessions_root.iterdir():
            if not source_dir.is_dir():
                continue
            archive_root = source_dir / "sessions"
            for path in archive_root.rglob("*.jsonl"):
                summary = summarize_session(path, source_dir.name, archive_root)
                if not summary:
                    continue
                rows.append(
                    {
                        "session_id": summary.session_id,
                        "title": summary.title,
                        "first_ts": summary.first_ts,
                        "last_ts": summary.last_ts,
                        "cwd": summary.cwd,
                        "model_provider": summary.model_provider,
                        "source_id": summary.source_id,
                        "archive_path": summary.archive_path,
                        "original_relpath": summary.original_relpath,
                        "user_messages": summary.user_messages,
                        "assistant_messages": summary.assistant_messages,
                        "searchable_text": summary.searchable_text,
                    }
                )
    rows.sort(key=lambda r: r.get("last_ts") or r.get("first_ts") or "", reverse=True)
    count = write_jsonl(vault / "index.jsonl", rows)
    write_search_md(vault, rows[:300])
    return count


def write_search_md(vault: Path, rows: list[dict[str, Any]]) -> None:
    path = vault / "search.md"
    ensure_dir(path.parent)
    lines = [
        "# Codex History Vault",
        "",
        f"Updated: {iso_now()}",
        "",
        "| Time | Title | Source | CWD | Thread |",
        "| --- | --- | --- | --- | --- |",
    ]
    for row in rows:
        title = str(row.get("title") or "").replace("|", "\\|").replace("\n", " ")
        cwd = str(row.get("cwd") or "").replace("|", "\\|")
        lines.append(
            f"| {row.get('last_ts') or row.get('first_ts') or ''} | {title[:120]} | "
            f"{row.get('source_id') or ''} | `{cwd}` | `{row.get('session_id') or ''}` |"
        )
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def read_index(vault: Path) -> list[dict[str, Any]]:
    path = vault / "index.jsonl"
    rows: list[dict[str, Any]] = []
    if not path.exists():
        return rows
    with path.open("r", encoding="utf-8", errors="replace") as fh:
        for raw in fh:
            try:
                rows.append(json.loads(raw))
            except json.JSONDecodeError:
                continue
    return rows


def snapshot(args: argparse.Namespace) -> int:
    vault = Path(args.vault).expanduser()
    ensure_dir(vault)
    sources = [Path(p).expanduser() for p in (args.source or [str(DEFAULT_CODEX_HOME)])]
    manifest_rows = []

    for source in sources:
        if not source.exists():
            print(f"skip missing source: {source}", file=sys.stderr)
            continue
        source_id = stable_source_id(source)
        copied_sessions = copy_tree_incremental(source / "sessions", vault / "sources" / source_id / "sessions")
        copied_attachments = copy_tree_incremental(source / "attachments", vault / "sources" / source_id / "attachments")
        copied_images = copy_tree_incremental(source / "generated_images", vault / "sources" / source_id / "generated_images")
        metadata_dst = vault / "sources" / source_id / "metadata"
        copied_meta = 0
        for name in ("session_index.jsonl", "history.jsonl", "models_cache.json", "config.toml.cc-switch-bak"):
            src = source / name
            if src.exists() and copy_if_changed(src, metadata_dst / name):
                copied_meta += 1

        sqlite_count = 0
        if not args.skip_sqlite:
            sqlite_src = source / "sqlite"
            sqlite_dst = vault / "snapshots" / now_stamp() / source_id / "sqlite"
            if sqlite_src.exists():
                for db in sqlite_src.glob("*.sqlite"):
                    if backup_sqlite_file(db, sqlite_dst / db.name):
                        sqlite_count += 1

        manifest_rows.append(
            {
                "captured_at": iso_now(),
                "source": str(source),
                "source_id": source_id,
                "sessions_changed": copied_sessions,
                "attachments_changed": copied_attachments,
                "images_changed": copied_images,
                "metadata_changed": copied_meta,
                "sqlite_backups": sqlite_count,
            }
        )

    ensure_dir(vault / "manifests")
    manifest = vault / "manifests" / f"snapshot-{now_stamp()}.json"
    manifest.write_text(json.dumps(manifest_rows, ensure_ascii=False, indent=2), encoding="utf-8")
    indexed = rebuild_index(vault)
    print(f"vault: {vault}")
    print(f"indexed sessions: {indexed}")
    for row in manifest_rows:
        print(
            f"{row['source_id']}: sessions +{row['sessions_changed']}, "
            f"attachments +{row['attachments_changed']}, images +{row['images_changed']}, "
            f"sqlite backups {row['sqlite_backups']}"
        )
    return 0


def merge_jsonl_unique(src: Path, dst: Path) -> int:
    if not src.exists():
        return 0
    ensure_dir(dst.parent)
    seen: set[str] = set()
    if dst.exists():
        with dst.open("r", encoding="utf-8", errors="replace") as fh:
            for raw in fh:
                seen.add(raw)
    added = 0
    with src.open("r", encoding="utf-8", errors="replace") as src_fh, dst.open("a", encoding="utf-8") as dst_fh:
        for raw in src_fh:
            if raw in seen:
                continue
            dst_fh.write(raw)
            seen.add(raw)
            added += 1
    return added


def restore_archive_to_source(vault: Path, source: Path) -> dict[str, int]:
    stats = {
        "sessions_restored": 0,
        "attachments_restored": 0,
        "images_restored": 0,
        "metadata_lines_added": 0,
    }
    sources_root = vault / "sources"
    if not sources_root.exists():
        return stats

    for archived_source in sources_root.iterdir():
        if not archived_source.is_dir():
            continue
        stats["sessions_restored"] += copy_tree_incremental(archived_source / "sessions", source / "sessions")
        stats["attachments_restored"] += copy_tree_incremental(archived_source / "attachments", source / "attachments")
        stats["images_restored"] += copy_tree_incremental(archived_source / "generated_images", source / "generated_images")

        metadata = archived_source / "metadata"
        stats["metadata_lines_added"] += merge_jsonl_unique(metadata / "session_index.jsonl", source / "session_index.jsonl")
        stats["metadata_lines_added"] += merge_jsonl_unique(metadata / "history.jsonl", source / "history.jsonl")

    return stats


def current_provider_for_source(source: Path, requested: str) -> str:
    if requested != "auto":
        return requested
    config = source / "config.toml"
    if config.exists():
        try:
            for raw in config.read_text(encoding="utf-8", errors="replace").splitlines():
                line = raw.strip()
                if not line.startswith("model_provider"):
                    continue
                _, _, value = line.partition("=")
                provider = value.strip().strip('"').strip("'")
                if provider:
                    return provider
        except OSError:
            pass
    cc_switch_db = Path.home() / ".cc-switch" / "cc-switch.db"
    if cc_switch_db.exists():
        try:
            with sqlite3.connect(f"file:{cc_switch_db}?mode=ro", uri=True) as conn:
                row = conn.execute(
                    """
                    SELECT id, name, category
                    FROM providers
                    WHERE app_type = 'codex' AND is_current = 1
                    LIMIT 1
                    """
                ).fetchone()
            if row:
                provider_id, _name, category = [str(v or "") for v in row]
                if provider_id not in {"codex-official", "default"} and category != "official":
                    return "custom"
                return "openai"
        except sqlite3.Error:
            pass
    return "openai"


def backup_state_db(db: Path, vault: Path, source: Path) -> Path:
    role = "root" if db.parent == source else "sqlite"
    backup_dir = vault / "sqlite-state-backups" / now_stamp()
    backup_path = backup_dir / f"{role}-{db.name}"
    if not backup_sqlite_file(db, backup_path):
        raise RuntimeError(f"failed to back up state database: {db}")
    return backup_path


def state_db_candidates(source: Path) -> list[Path]:
    seen: set[Path] = set()
    candidates: list[Path] = []
    for db in (source / "state_5.sqlite", source / "sqlite" / "state_5.sqlite"):
        if not db.exists():
            continue
        try:
            key = db.resolve()
        except OSError:
            key = db
        if key in seen:
            continue
        seen.add(key)
        candidates.append(db)
    return candidates


def sync_one_state_db(db: Path, source: Path, vault: Path, provider: str, records: list[StateThreadRecord]) -> dict[str, Any]:
    stats: dict[str, Any] = {
        "db": str(db),
        "provider": provider,
        "parsed": len(records),
        "inserted": 0,
        "provider_updated": 0,
        "backup": "",
        "skipped": False,
    }
    if not records:
        return stats

    backup_path = backup_state_db(db, vault, source)
    stats["backup"] = str(backup_path)

    with sqlite3.connect(db) as conn:
        conn.execute("PRAGMA busy_timeout=5000")
        before = conn.total_changes
        for record in records:
            conn.execute(
                """
                INSERT OR IGNORE INTO threads (
                    id, rollout_path, created_at, updated_at, source, model_provider, cwd, title,
                    sandbox_policy, approval_mode, tokens_used, has_user_event, archived,
                    cli_version, first_user_message, model, reasoning_effort, thread_source,
                    preview, created_at_ms, updated_at_ms
                )
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 0, ?, 0, ?, ?, ?, ?, ?, ?, ?, ?)
                """,
                (
                    record.session_id,
                    record.rollout_path,
                    record.created_at,
                    record.updated_at,
                    record.source,
                    record.model_provider,
                    record.cwd,
                    record.title,
                    record.sandbox_policy,
                    record.approval_mode,
                    record.has_user_event,
                    record.cli_version,
                    record.first_user_message,
                    record.model,
                    record.reasoning_effort,
                    record.thread_source,
                    record.preview,
                    record.created_at * 1000,
                    record.updated_at * 1000,
                ),
            )
        stats["inserted"] = conn.total_changes - before
        before = conn.total_changes
        conn.execute("UPDATE threads SET model_provider = ? WHERE model_provider IS NULL OR model_provider != ?", (provider, provider))
        stats["provider_updated"] = conn.total_changes - before
        conn.commit()
    return stats


def sync_state_dbs(source: Path, vault: Path, provider: str) -> list[dict[str, Any]]:
    sessions = source / "sessions"
    records: list[StateThreadRecord] = []
    if sessions.exists():
        for path in sessions.rglob("*.jsonl"):
            record = parse_state_thread(path)
            if record:
                record.model_provider = provider
                records.append(record)

    dbs = state_db_candidates(source)
    if not dbs:
        return [
            {
                "db": str(source / "state_5.sqlite"),
                "provider": provider,
                "parsed": len(records),
                "inserted": 0,
                "provider_updated": 0,
                "backup": "",
                "skipped": True,
            }
        ]
    return [sync_one_state_db(db, source, vault, provider, records) for db in dbs]


def mirror(args: argparse.Namespace) -> int:
    snapshot(args)
    vault = Path(args.vault).expanduser()
    sources = [Path(p).expanduser() for p in (args.source or [str(DEFAULT_CODEX_HOME)])]
    for source in sources:
        ensure_dir(source)
        stats = restore_archive_to_source(vault, source)
        print(
            f"restored into {source}: sessions +{stats['sessions_restored']}, "
            f"attachments +{stats['attachments_restored']}, images +{stats['images_restored']}, "
            f"metadata lines +{stats['metadata_lines_added']}"
        )
        if args.sync_state_db:
            provider = current_provider_for_source(source, args.state_provider)
            for state_stats in sync_state_dbs(source, vault, provider):
                if state_stats.get("skipped"):
                    print(f"state db skipped: {state_stats['db']}")
                else:
                    print(
                        f"state db synced: {state_stats['db']}: parsed {state_stats['parsed']}, "
                        f"inserted {state_stats['inserted']}, provider relabeled {state_stats['provider_updated']} "
                        f"-> {state_stats['provider']}"
                    )
    return 0


def list_sessions(args: argparse.Namespace) -> int:
    rows = read_index(Path(args.vault).expanduser())[: args.limit]
    for row in rows:
        print(f"{row.get('last_ts') or row.get('first_ts') or ''}  {row.get('session_id')}  {row.get('title')}")
    return 0


def search(args: argparse.Namespace) -> int:
    query = " ".join(args.query).lower()
    rows = read_index(Path(args.vault).expanduser())
    hits: list[dict[str, Any]] = []
    for row in rows:
        haystack = "\n".join(
            str(row.get(k) or "")
            for k in ("session_id", "title", "cwd", "model_provider", "searchable_text")
        ).lower()
        if query in haystack:
            hits.append(row)
    for row in hits[: args.limit]:
        print(f"{row.get('last_ts') or row.get('first_ts') or ''}  {row.get('session_id')}  {row.get('title')}")
        print(f"  cwd: {row.get('cwd')}")
    print(f"hits: {len(hits)}")
    return 0


def find_session(vault: Path, needle: str) -> dict[str, Any] | None:
    for row in read_index(vault):
        sid = str(row.get("session_id") or "")
        title = str(row.get("title") or "")
        if sid == needle or sid.startswith(needle) or needle.lower() in title.lower():
            return row
    return None


def show(args: argparse.Namespace) -> int:
    vault = Path(args.vault).expanduser()
    row = find_session(vault, args.session)
    if not row:
        print(f"session not found: {args.session}", file=sys.stderr)
        return 1
    path = Path(str(row["archive_path"]))
    printed = 0
    with path.open("r", encoding="utf-8", errors="replace") as fh:
        for raw in fh:
            try:
                event = json.loads(raw)
            except json.JSONDecodeError:
                continue
            if event.get("type") != "response_item":
                continue
            payload = event.get("payload") or {}
            if not isinstance(payload, dict) or payload.get("type") != "message":
                continue
            role = payload.get("role")
            if role not in {"user", "assistant"}:
                continue
            text = extract_text(payload.get("content"))
            if not text:
                continue
            print(f"\n[{role}] {event.get('timestamp') or ''}\n{text}")
            printed += 1
            if args.limit and printed >= args.limit:
                break
    return 0


def restore(args: argparse.Namespace) -> int:
    vault = Path(args.vault).expanduser()
    row = find_session(vault, args.session)
    if not row:
        print(f"session not found: {args.session}", file=sys.stderr)
        return 1
    src = Path(str(row["archive_path"]))
    dest_home = Path(args.dest).expanduser()
    rel = Path(str(row.get("original_relpath") or src.name))
    dst = dest_home / "sessions" / rel
    if args.dry_run:
        print(f"would copy {src} -> {dst}")
        return 0
    changed = copy_if_changed(src, dst)
    print(f"{'restored' if changed else 'already present'}: {dst}")
    print("Tip: restart Codex Desktop if the thread list does not refresh immediately.")
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Archive, search, and restore Codex Desktop chat history.")
    parser.add_argument("--vault", default=str(DEFAULT_VAULT), help=f"history vault path (default: {DEFAULT_VAULT})")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_snapshot = sub.add_parser("snapshot", aliases=["sync"], help="incrementally archive current Codex history")
    p_snapshot.add_argument("--source", action="append", default=None, help="Codex home to archive")
    p_snapshot.add_argument("--skip-sqlite", action="store_true", help="skip SQLite snapshots for lightweight frequent sync")
    p_snapshot.set_defaults(func=snapshot)

    p_mirror = sub.add_parser("mirror", help="archive current history, then restore archived sessions into each source")
    p_mirror.add_argument("--source", action="append", default=None, help="Codex home to archive and backfill")
    p_mirror.add_argument("--skip-sqlite", action="store_true", help="skip SQLite snapshots for lightweight frequent sync")
    p_mirror.add_argument("--sync-state-db", action="store_true", help="rebuild Codex Desktop state_5.sqlite thread index")
    p_mirror.add_argument("--state-provider", default="auto", help="provider label for state DB rows; auto reads config.toml, defaulting to openai")
    p_mirror.set_defaults(func=mirror)

    p_list = sub.add_parser("list", help="list archived sessions")
    p_list.add_argument("--limit", type=int, default=30)
    p_list.set_defaults(func=list_sessions)

    p_search = sub.add_parser("search", help="search archived sessions")
    p_search.add_argument("query", nargs="+")
    p_search.add_argument("--limit", type=int, default=20)
    p_search.set_defaults(func=search)

    p_show = sub.add_parser("show", help="print a session transcript")
    p_show.add_argument("session", help="session id prefix or title substring")
    p_show.add_argument("--limit", type=int, default=0, help="max messages to print")
    p_show.set_defaults(func=show)

    p_restore = sub.add_parser("restore-session", help="restore one archived session into a Codex home")
    p_restore.add_argument("session", help="session id prefix or title substring")
    p_restore.add_argument("--dest", default=str(DEFAULT_CODEX_HOME), help="destination Codex home")
    p_restore.add_argument("--dry-run", action="store_true")
    p_restore.set_defaults(func=restore)

    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
